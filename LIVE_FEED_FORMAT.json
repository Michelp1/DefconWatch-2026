{
  "schemaVersion": "2.4",
  "appVersion": "2.4.0",
  "refreshIntervalMinutes": 10,
  "feeds": [
    {
      "id": "usgs-significant-day",
      "category": "AARDBEVING",
      "format": "GeoJSON",
      "url": "https://earthquake.usgs.gov/earthquakes/feed/v1.0/summary/significant_day.geojson"
    },
    {
      "id": "gdacs-rss",
      "category": "RAMP",
      "format": "RSS/XML",
      "url": "https://www.gdacs.org/xml/rss.xml"
    },
    {
      "id": "iss-position",
      "category": "SPACE",
      "format": "JSON",
      "url": "https://api.wheretheiss.at/v1/satellites/25544"
    }
  ],
  "supportedTypes": ["AARDBEVING", "STORM", "VULKAAN", "OVERSTROMING", "BOSBRAND", "TSUNAMI", "SPACE", "RAMP"],
  "severityScale": {
    "1": "informatief",
    "2": "laag",
    "3": "verhoogd",
    "4": "hoog",
    "5": "kritiek"
  },
  "mapCapabilities": {
    "drag": true,
    "pinchZoom": true,
    "zoomButtons": true,
    "reset": true,
    "minZoom": 1.0,
    "maxZoom": 4.0
  },
  "requiredIncidentFields": ["type", "title", "source", "url", "lat", "lon", "severity"],
  "disclaimer": "De readiness-index is geen officieel of geclassificeerd DEFCON-niveau."
}
